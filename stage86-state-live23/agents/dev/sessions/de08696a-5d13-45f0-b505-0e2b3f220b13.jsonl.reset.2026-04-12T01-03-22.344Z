фон: +7 (495) 123-45-67  \nEmail: info@ventplus.ru","filename":"business_proposal_ventilation.pdf"}}],"api":"openai-completions","provider":"hydra","model":"gpt-4o","usage":{"input":16132,"output":523,"cacheRead":0,"cacheWrite":0,"totalTokens":16655,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775941205832,"responseId":"chat-id-45f70a57-d4e1-4677-a5c5-804f14d307e3"}}
